generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  price         Int
  discountPrice Int?
  category      String
  tags          String?
  featured      Boolean  @default(false)
  badge         String?  // "NEW ARRIVAL", "BEST SELLER", "SALE"
  stockQuantity Int      @default(0)
  condition     String   @default("new") // "new", "pre_order", "limited", "vintage"
  status        String   @default("draft") // "draft", "active", "archived"
  seoTitle      String?
  seoDescription String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]
  reviews  Review[]
  orderItems OrderItem[]
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([featured])
  @@index([slug])
  @@index([status])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  imageUrl  String
  altText   String?
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id           String @id @default(cuid())
  productId    String
  variantType  String // "color" or "size"
  variantValue String // "Black", "Large", etc.
  stockQuantity Int   @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String?
  phone     String?
  role      String   @default("customer") // "customer" or "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]
  reviews     Review[]
  wishlistItems WishlistItem[]
  addresses   Address[]
  carts       Cart[]
  notes       CustomerNote[]
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String?
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  totalAmount     Int
  deliveryFee     Int      @default(0)
  paymentStatus   String   @default("pending") // "pending", "paid", "failed"
  paymentMethod   String   @default("paystack") // "paystack", "pay_on_delivery"
  orderStatus     String   @default("pending") // "pending", "paid", "processing", "shipped", "delivered", "cancelled"
  shippingAddress String?
  shippingState   String?
  deliveryConfirmedAt DateTime?
  deliveredAt      DateTime?
  shipmentReference String?
  adminNotes       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  items OrderItem[]
  activity AnalyticsEvent[]
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  selectedColor   String?
  selectedSize    String?
  itemPrice       Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model WishlistItem {
  id        String @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?
  guestId   String?
  email     String?
  items     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([guestId])
  @@index([email])
}

model Review {
  id               String   @id @default(cuid())
  userId           String?
  productId        String
  authorName       String
  rating           Int
  comment          String
  verifiedPurchase Boolean  @default(false)
  createdAt        DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([authorName, productId])
  @@index([productId])
}

model Address {
  id        String @id @default(cuid())
  userId    String
  fullName  String
  phone     String
  address   String
  state     String
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percentage") // "percentage" or "fixed"
  value       Int      // percentage value (e.g. 10 for 10%) or fixed amount in kobo
  minOrder    Int      @default(0) // minimum order amount in kobo
  maxDiscount Int?     // max discount amount in kobo (for percentage type)
  usageLimit  Int?     // total times this code can be used
  usageCount  Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  campaignType String  @default("standard") // "standard", "giveaway", "flash_sale"
  bannerTitle String?
  bannerCopy  String?
  startsAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomepageBanner {
  id        String   @id @default(cuid())
  title     String
  copy      String?
  imageUrl  String?
  ctaLabel  String?
  ctaTarget String?
  isActive  Boolean  @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  entityType String?
  entityId  String?
  orderId   String?
  email     String?
  metadata  String?
  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([orderId])
  @@index([email])
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
}

model PendingPayment {
  id        String   @id @default(cuid())
  reference String   @unique
  email     String
  amount    Int
  payload   String
  status    String   @default("initialized")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}
